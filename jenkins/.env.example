# =============================================================================
# Jenkins Stack Environment Variables
# Copy this file to .env and fill in your actual secrets.
# Do NOT commit the .env file to version control.
# =============================================================================

# ── DockerHub ────────────────────────────────────────────────────────────
# Used by Jenkins to push images
DOCKERHUB_USERNAME=aboelaiz
DOCKERHUB_PASSWORD=REPLACE_WITH_DOCKERHUB_PASSWORD_OR_ACCESS_TOKEN

# ── GitHub ───────────────────────────────────────────────────────────────
# Used by Jenkins to pull code and push GitOps updates back to the repo
# Create a Personal Access Token (PAT) with 'repo' and 'workflow' scopes
GITHUB_USERNAME=YOUR_GITHUB_USERNAME
GITHUB_TOKEN=REPLACE_WITH_GITHUB_PAT

# ── Slack ────────────────────────────────────────────────────────────────
# Used by Jenkins to send build status notifications
SLACK_WEBHOOK_URL=REPLACE_WITH_SLACK_WEBHOOK_URL
